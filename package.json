{
  "name": "ahang-skills-manager",
  "version": "1.3.1",
  "description": "多 AI 工具 Skills 统一管理平台 — 支持 Claude、Cursor、CodeBuddy、Copilot 等",
  "type": "module",
  "bin": {
    "ahang-skills-manager": "dist/server/server/cli.js"
  },
  "files": [
    "dist/",
    "templates/",
    "data/config.example.json",
    "public/"
  ],
  "scripts": {
    "dev": "concurrently -k -n CLIENT,SERVER -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "stop": "lsof -ti:3001 | xargs kill -9 2>/dev/null; lsof -ti:5173 | xargs kill -9 2>/dev/null; lsof -ti:5174 | xargs kill -9 2>/dev/null; echo '✅ 已关闭项目并清理端口 3001/5173/5174'",
    "dev:client": "vite",
    "dev:server": "tsx --watch server/index.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "npm run build && npm run build:server",
    "prepublishOnly": "npm run build:all",
    "start": "node dist/server/server/index.js",
    "preview": "vite preview"
  },
  "keywords": [
    "skills",
    "ai",
    "cursor",
    "claude",
    "copilot",
    "codebuddy",
    "manager",
    "prompt"
  ],
  "author": "阿航",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hello-ahang/Skills_Manager.git"
  },
  "homepage": "https://github.com/hello-ahang/Skills_Manager#readme",
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "fs-extra": "^11.2.0",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.52.0",
    "multer": "^1.4.5-lts.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "unzipper": "^0.12.3",
    "uuid": "^11.0.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/unzipper": "^0.10.10",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
